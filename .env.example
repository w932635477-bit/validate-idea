# validate-idea 数据抓取 env —— 全部可选,缺了对应源就 ok:false(优雅降级,不崩)。
# 复制本文件为 .env,按需填。评分由跑 skill 的 Claude 做,不需要任何 LLM key。

# Firecrawl(两个市场的 search 维度都靠它,数据质量最好,建议填)
FIRECRAWL_API_KEY=

# 知乎 cookie(中文社区)。浏览器登录知乎 → F12 → Network → 任一请求的 Cookie 头,整段复制。
ZHIHU_COOKIE=

# 本地代理(在中国抓英文源 hn/lobsters/brave/firecrawl 时经此代理出;海外或不被墙可留空)
HTTPS_PROXY=
# HTTP_PROXY=

# Brave Search key(英文竞品维度;无 key 时用 HN Show HN 发布帖兜底)
BRAVE_SEARCH_API_KEY=
